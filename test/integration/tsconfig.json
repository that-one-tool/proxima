{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@repo/typescript/tsconfig.base.json",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"skipLibCheck": true,
		"types": ["node"],
		"baseUrl": "."
	},
	"include": ["./src/**/*.ts", "./test/**/*.ts"],
	"exclude": ["./node_modules"]
}
