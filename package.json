{
	"name": "@that-one-tool/proxima",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"build:force": "turbo build --force",
		"check": "turbo build lint test",
		"check:fix": "turbo build format lint:fix test",
		"check:force": "turbo build lint test --force",
		"clear:all": "npm run clear:build && npm run clear:turbo",
		"clear:build": "turbo clear:build --force",
		"clear:turbo": "turbo clear:turbo --force && rm -rf ./.turbo",
		"format": "prettier --write \"**/*.{js,mjs,ts,tsx,md}\"",
		"lint": "turbo lint",
		"lint:fix": "turbo lint -- --fix",
		"start:all": "docker compose -f docker/docker-compose.yml up -d",
		"start:dev": "turbo start:dev",
		"stop:all": "docker compose -f docker/docker-compose.yml down"
	},
	"packageManager": "npm@10.9.2",
	"engines": {
		"node": ">=22"
	},
	"workspaces": [
		"config/*",
		"packages/*"
	],
	"devDependencies": {
		"prettier": "^3.5.3",
		"turbo": "^2.5.0",
		"typescript": "^5.8.3"
	}
}
