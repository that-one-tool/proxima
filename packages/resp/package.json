{
	"name": "@that-one-tool/proxima-resp",
	"version": "0.1.0",
	"description": "A minimalist TCP reverse proxy for redis-based server",
	"main": "dist/index.js",
	"scripts": {
		"build": "rm -rf dist && node esbuild.config.mjs",
		"check-types": "tsc --noEmit",
		"clear:build": "rm -rf dist && rm -rf .cache",
		"clear:turbo": "rm -rf .turbo",
		"start": "node dist/index.js",
		"start:dev": "npm run build && node --env-file=.env dist/index.js",
		"lint": "eslint . --max-warnings 0",
		"test": "jest"
	},
	"author": "Jason Mejane",
	"license": "MIT",
	"keywords": [
		"tcp",
		"redis",
		"proxy",
		"tcp-proxy",
		"redis-proxy",
		"server"
	],
	"dependencies": {
		"@that-one-tool/proxima-core": "*"
	},
	"devDependencies": {
		"@repo/eslint": "*",
		"@repo/typescript": "*",
		"@types/jest": "^30.0.0",
		"@types/node": "^24",
		"esbuild": "^0.28.1",
		"jest": "^30.4.2",
		"ts-jest": "^29.4.11",
		"typescript": "^5.9.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec.ts$",
		"transform": {
			"^.+\\.(t|j)s$": [
				"ts-jest",
				{
					"isolatedModules": true
				}
			]
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
