{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./.cache/tsconfig.tsbuildinfo",
		"outDir": "./dist/",
		"rootDir": "./src",
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["./build", "./dist", "./test", "./node_modules"]
}
