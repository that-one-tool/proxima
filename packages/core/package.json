{
	"name": "@that-one-tool/proxima-core",
	"version": "0.1.0",
	"description": "A minimalist TCP proxy for redis server",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "rm -rf dist && tsc --build tsconfig.build.json",
		"check-types": "tsc --noEmit",
		"clear:build": "rm -rf dist && rm -rf .cache",
		"clear:turbo": "rm -rf .turbo",
		"lint": "eslint . --max-warnings 0"
	},
	"author": "Jason Mejane",
	"license": "MIT",
	"keywords": [
		"tcp",
		"redis",
		"proxy",
		"tcp-proxy",
		"redis-proxy",
		"server"
	],
	"dependencies": {
		"prom-client": "^15.1.3",
		"winston": "^3.17.0"
	},
	"devDependencies": {
		"@repo/eslint": "*",
		"@repo/typescript": "*",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.14.0",
		"jest": "^29.7.0",
		"ts-jest": "^29.3.1",
		"typescript": "^5.8.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"transform": {
			"^.+\\.(t|j)s$": [
				"ts-jest",
				{
					"isolatedModules": true
				}
			]
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
