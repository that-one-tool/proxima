{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"clear:build": {
			"dependsOn": ["^clear:build"]
		},
		"clear:turbo": {
			"dependsOn": ["^clear:turbo"]
		},
		"start:dev": {
			"dependsOn": ["^start:dev"]
		},
		"test": {
			"dependsOn": ["^test"]
		}
	}
}
